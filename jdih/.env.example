#--------------------------------------------------------------------
# ENVIRONMENT
#--------------------------------------------------------------------
CI_ENVIRONMENT=development

#--------------------------------------------------------------------
# APP
#--------------------------------------------------------------------
app.baseURL="https://jdih.padang.go.id/"
app.forceGlobalSecureRequests="true"

# Session Configuration
app.sessionDriver="CodeIgniter\\Session\\Handlers\\FileHandler"
app.sessionCookieName="ci_session"
app.sessionSavePath="ci_sessions"
app.sessionMatchIP="false"
app.sessionTimeToUpdate="300"
app.sessionRegenerateDestroy="false"

# Cookie Configuration
app.cookiePrefix=""
app.cookieDomain=""
app.cookiePath="/"
app.cookieSecure="false"
app.cookieHTTPOnly="true"

# CSRF Protection
app.CSRFProtection="true"
app.CSRFTokenName="csrf_test_name"
app.CSRFCookieName="csrf_cookie_name"
app.CSRFExpire="7200"
app.CSRFRegenerate="true"
app.CSRFExcludeURIs=""

# Content Security Policy
app.CSPEnabled="false"

#--------------------------------------------------------------------
# TTE CONFIGURATION
#--------------------------------------------------------------------
TTE_API_URL=http://YOUR_TTE_HOST
TTE_API_KEY=your_api_key_here
TTE_CLIENT_ID=your_client_id
TTE_CLIENT_SECRET=your_client_secret
TTE_API_TIMEOUT=30
TTE_API_DEBUG=false

#--------------------------------------------------------------------
# DATABASE
#--------------------------------------------------------------------
database.default.hostname = localhost
database.default.database = jdih_db
database.default.username = root
database.default.password = YOUR_DB_PASSWORD
database.default.DBDriver = MySQLi

#--------------------------------------------------------------------
# PYTHON CONFIGURATION
#--------------------------------------------------------------------
PYTHON_PATH="/usr/bin/python3"
python.script_dir="app/PdfTools/"
python.temp_dir="writable/temp/"

#--------------------------------------------------------------------
# GOOGLE RECAPTCHA
#--------------------------------------------------------------------
recaptcha.siteKey="YOUR_RECAPTCHA_SITE_KEY"
recaptcha.secretKey="YOUR_RECAPTCHA_SECRET_KEY"

#--------------------------------------------------------------------
# GEMINI API KEY
#--------------------------------------------------------------------
GEMINI_API_KEY="YOUR_GEMINI_API_KEY"

#--------------------------------------------------------------------
# ESIGN (TTE)
#--------------------------------------------------------------------
esign.client_id=jdih
esign.client_secret=YOUR_ESIGN_SECRET
esign.host=http://YOUR_ESIGN_HOST/api/v2

#--------------------------------------------------------------------
# LOGGING
#--------------------------------------------------------------------
app.logThreshold=4
